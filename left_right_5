                                        <span onClick={() => handleAuthAction(() => setEditingIdx(i))} className="text-[10px] font-bold text-slate-700 truncate w-full text-center cursor-pointer">{p}</span>
                                    )}
                                    <span className={`text-[19px] font-black leading-none my-1.5 ${totals[i]>0?'text-[#3b82f6]':totals[i]<0?'text-[#ef4444]':'text-slate-800'}`}>
                                        {totals[i]>0?`+${totals[i]}`:totals[i]}
                                    </span>
                                    {rankingInfo && <span className="text-[8px] font-medium text-slate-400 bg-slate-50 w-full text-center rounded-sm py-0.5">{rankingInfo[i].toLocaleString()}</span>}
                                </div>
                            ))}
                        </div>
                    </div>

                    {/* 단일 홀 입력 메인 뷰 */}
                    <div className="flex-1 overflow-y-auto p-4 flex flex-col justify-center relative">
                        <div className="bg-white rounded-3xl shadow-[0_8px_30px_rgba(0,0,0,0.06)] border border-slate-100 p-5 relative">
                            
                            <div className="flex justify-between items-center mb-6 relative">
                                <button onClick={() => changeHole(currentHoleIdx - 1)} disabled={currentHoleIdx === 0} 
                                    className={`w-10 h-10 flex items-center justify-center rounded-full bg-slate-50 border border-slate-100 text-slate-600 transition-all ${currentHoleIdx === 0 ? 'opacity-30' : 'hover:bg-slate-100 active:scale-90'}`}>
                                    <Icon name="chevronLeft" size={20} />
                                </button>
                                <div className="text-center">
                                    <p className="text-[11px] font-bold text-emerald-600 mb-[-4px] tracking-wide">CURRENT HOLE</p>
                                    <h2 className="text-[3rem] leading-none font-black italic text-slate-800">{currentHoleData.number}</h2>
                                </div>
                                <button onClick={() => changeHole(currentHoleIdx + 1)} disabled={currentHoleIdx === 17} 
                                    className={`w-10 h-10 flex items-center justify-center rounded-full bg-slate-50 border border-slate-100 text-slate-600 transition-all ${currentHoleIdx === 17 ? 'opacity-30' : 'hover:bg-slate-100 active:scale-90'}`}>
                                    <Icon name="chevronRight" size={20} />
                                </button>
                            </div>

                            {currentHoleData.isDraw ? (
                                <div className="py-12 flex flex-col items-center justify-center bg-[#f8fafc] rounded-2xl border-2 border-dashed border-slate-300">
                                    <p className="text-xl font-black text-slate-500 tracking-widest uppercase">Draw Game</p>
                                    <p className="text-[13px] text-slate-400 mt-1.5 font-bold">비김 처리된 홀입니다.</p>
                                </div>
                            ) : (
                                <div className="grid grid-cols-2 gap-3">
                                    {players.slice(0, 5).map((p, pi) => {
                                        const isSolo = currentHoleData.soloIndex === pi;
                                        const win = currentHoleData.winners.includes(pi);
                                        const lose = isSoloSelected && isCurrentHoleDone && !win && !isSolo;
                                        
                                        // 모바일 드래그 방지를 위한 select-none 추가
                                        let btnClass = "relative h-24 rounded-2xl transition-transform active:scale-95 flex flex-col items-center justify-center shadow-sm overflow-hidden select-none ";
                                        let pointText = "";
                                        let roleText = p;
                                        let pointColorClass = "text-2xl leading-none font-black";

                                        if (!isSoloSelected) {
                                            btnClass += "bg-white border-2 border-emerald-100 text-emerald-600 hover:bg-emerald-50";
                                            pointText = "1인 선택";
                                        } else if (isSolo) {
                                            btnClass += "bg-purple-500 text-white shadow-[0_4px_12px_rgba(168,85,247,0.3)] border-b-[4px] border-purple-700";
                                            pointText = currentHoleData.soloPoints > 0 ? `+${currentHoleData.soloPoints}` : currentHoleData.soloPoints;
                                            roleText = `${p} (1인)`;
                                        } else if (win) {
                                            btnClass += "bg-[#f59e0b] text-white shadow-[0_4px_12px_rgba(245,158,11,0.3)] border-b-[4px] border-[#d97706]";
                                            pointText = `+${currentHoleData.points}`;
                                        } else if (lose) {
                                            btnClass += "bg-[#1e293b] text-white shadow-[0_4px_12px_rgba(30,41,59,0.3)] border-b-[4px] border-[#0f172a]";
                                            pointText = `-${currentHoleData.points}`;
                                        } else {
                                            btnClass += "bg-white border-2 border-slate-100 text-slate-400 hover:border-slate-200 hover:bg-slate-50";
                                            pointText = "WIN";
                                            pointColorClass = "text-xl leading-none font-black text-slate-300"; // 안 눌린 버튼 글씨 약간 작게
                                        }

                                        return (
                                            <button 
                                                key={pi} 
                                                onPointerDown={(e) => {
                                                    if (e.button !== 0 && e.pointerType === 'mouse') return;
                                                    handlePressStart(currentHoleIdx, pi);
                                                }}
                                                onPointerUp={(e) => {
                                                    if (e.button !== 0 && e.pointerType === 'mouse') return;
                                                    handlePressEnd(currentHoleIdx, pi);
                                                }}
                                                onPointerLeave={handlePressCancel}
                                                onPointerCancel={handlePressCancel}
                                                onContextMenu={(e) => { e.preventDefault(); return false; }}
                                                style={{ WebkitTouchCallout: 'none' }}
                                                className={`${btnClass} ${pi === 4 ? 'col-span-2' : ''}`}
                                            >
                                                <span className={`text-[12px] font-bold mb-0.5 truncate w-full px-1 ${!isSoloSelected || win || lose || isSolo ? 'opacity-90' : 'text-slate-400'}`}>{roleText}</span>
                                                <span className={pointColorClass}>{pointText}</span>
                                            </button>
                                        );
                                    })}
                                </div>
                            )}

                            <div className="mt-6 flex gap-2.5">
                                <button onClick={handleDrawToggle} className={`flex-1 py-3.5 rounded-xl font-bold text-[14px] border-2 transition-all ${currentHoleData.isDraw ? 'bg-slate-100 border-slate-200 text-slate-500' : 'bg-white border-emerald-500 text-emerald-600 active:bg-emerald-50'}`}>
                                    {currentHoleData.isDraw ? '비김 취소' : '비김 (DRAW) 처리'}
                                </button>
                                
                                {isCurrentHoleDone && currentHoleIdx < 17 && (
                                    <button onClick={() => changeHole(currentHoleIdx + 1)} className="flex-1 py-3.5 rounded-xl font-bold text-[14px] bg-emerald-600 text-white shadow-[0_4px_12px_rgba(5,150,105,0.4)] active:scale-95 flex items-center justify-center">
                                        다음 홀 <Icon name="chevronRight" size={16} className="ml-0.5"/>
                                    </button>
                                )}
                            </div>

                        </div>
                    </div>

                    {/* 전체 스코어보드 보기 (하단 고정 바) */}
                    <div className="bg-[#1e293b] text-white shrink-0">
                        <button onClick={() => setIsScoreboardOpen(true)} className="w-full py-4 font-bold text-[14px] active:bg-[#0f172a] transition-colors flex items-center justify-center gap-2">
                            <Icon name="list" size={18} />
                            전체 스코어보드 보기
                        </button>
                    </div>

                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
