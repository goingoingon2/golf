            const currentHoleData = holes[currentHoleIdx];
            const isSoloSelected = currentHoleData.soloIndex !== null && currentHoleData.soloIndex !== undefined;
            const isCurrentHoleDone = isSoloSelected && currentHoleData.winners.length === 2;

            // -------------------------------------------------------------
            // 2. 메인 & 스코어보드 뷰
