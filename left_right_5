                    {/* 초기화 확인 모달 */}
                    {isResetConfirmOpen && (
                        <div className="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in">
                            <div className="bg-white w-full max-w-xs rounded-3xl shadow-2xl p-6 text-center">
                                <div className="w-16 h-16 bg-rose-50 text-rose-500 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <Icon name="alert" size={32} />
                                </div>
                                <h3 className="text-xl font-bold mb-2 text-slate-800">초기화하시겠습니까?</h3>
                                <p className="text-xs text-slate-500 leading-relaxed">참여 중인 모든 사람의<br/>화면이 초기화됩니다.</p>
                                <div className="flex gap-3 mt-6">
                                    <button onClick={() => setIsResetConfirmOpen(false)} className="flex-1 py-4 bg-slate-100 text-slate-600 rounded-2xl font-bold active:scale-95 transition-transform">취소</button>
                                    <button onClick={() => handleAuthAction(executeReset)} className="flex-1 py-4 bg-rose-500 text-white rounded-2xl font-bold active:scale-95 shadow-md transition-transform">확인</button>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* 메인 화면 비밀번호 인증 모달 */}
                    {isAuthModalOpen && (
                        <div className="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in">
                            <div className="bg-white w-full max-w-xs rounded-3xl shadow-2xl p-6 text-center">
                                <div className="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <Icon name="lock" size={32} />
                                </div>
                                <h3 className="text-xl font-bold mb-2 text-slate-800">관리자 인증</h3>
                                <p className="text-xs text-slate-500 leading-relaxed mb-4">점수 입력 및 수정을 위해<br/>비밀번호를 입력해주세요.</p>
                                <form onSubmit={handleAuthSubmit}>
                                    <input type="password" inputMode="numeric" pattern="\d*" value={authPassword} onChange={(e) => setAuthPassword(e.target.value)} placeholder="비밀번호(7905)" className="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-center font-bold tracking-widest outline-none focus:ring-2 focus:ring-emerald-500 mb-6" autoFocus />
                                    <div className="flex gap-3">
                                        <button type="button" onClick={() => {
