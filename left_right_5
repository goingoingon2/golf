<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>좌탄우탄 스코어보드 5인</title>
    <!-- React 및 라이브러리 로드 -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; -webkit-tap-highlight-color: transparent; background-color: #f8fafc; }
        .animate-in { animation: fadeIn 0.2s ease-out; }
        .animate-slide-up { animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideUp { from { opacity: 0; transform: translateY(100%); } to { opacity: 1; transform: translateY(0); } }
        
        /* 커스텀 스크롤바 숨기기 */
        ::-webkit-scrollbar { width: 0px; background: transparent; }
        
        /* 뷰포트 높이 안정화 */
        .app-container { height: 100dvh; display: flex; flex-direction: column; overflow: hidden; }
    </style>

    <!-- Firebase SDK 안전한 동적 로드 방식 -->
    <script type="module">
        (async () => {
            try {
                const [app, auth, firestore] = await Promise.all([
                    import('https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js'),
                    import('https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js'),
                    import('https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js')
                ]);
                window.FirebaseSDK = {
                    initializeApp: app.initializeApp,
                    getAuth: auth.getAuth,
                    signInAnonymously: auth.signInAnonymously,
                    signInWithCustomToken: auth.signInWithCustomToken,
                    onAuthStateChanged: auth.onAuthStateChanged,
                    getFirestore: firestore.getFirestore,
                    doc: firestore.doc,
                    setDoc: firestore.setDoc,
                    onSnapshot: firestore.onSnapshot,
                    collection: firestore.collection
                };
            } catch (err) {
                console.error("Firebase SDK Load Error:", err);
                window.FirebaseSDKError = err.message || "스크립트 로드 실패";
            } finally {
                window.dispatchEvent(new Event('firebaseLoaded'));
            }
        })();
    </script>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useMemo, useEffect, useRef } = React;

        // ⛳️ 사용자님의 Firebase 설정값이 입력된 부분입니다!
        const appId = 'my-golf-group-1';
        const firebaseConfig = {
            apiKey: "AIzaSyALzYLoBWl-oHCyLzEr7YefqqySx8ESEjA",
            authDomain: "left-right-6da31.firebaseapp.com",
            projectId: "left-right-6da31",
            storageBucket: "left-right-6da31.firebasestorage.app",
            messagingSenderId: "128347797181",
            appId: "1:128347797181:web:3e1cdfe3e8d2efcde3a9d4"
        };
        const initialAuthToken = null;

        let db, auth;

        // 아이콘 컴포넌트
        const Icon = ({ name, size = 20, className = "" }) => {
            const icons = {
                trophy: <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6M18 9h1.5a2.5 2.5 0 0 0 0-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22h10c0-1.76-.85-3.25-2.03-3.79-.5-.23-.97-.66-.97-1.21v-2.34M12 2a5 5 0 0 0-5 5c0 3.5 3 5.5 5 5.5s5-2 5-5.5a5 5 0 0 0-5-5z"/>,
                users: <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>,
                rotate: <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8M3 3v5h5"/>,
                share: <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13"/>,
                wallet: <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4M3 5v14a2 2 0 0 0 2 2h16v-5M18 12a2 2 0 0 0 0 4h4v-4Z"/>,
                settings: <><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2Z"/><circle cx="12" cy="12" r="3"/></>,
                check: <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4L12 14.01l-3-3"/>,
                minus: <line x1="5" y1="12" x2="19" y2="12"/>,
                chevronDown: <polyline points="6 9 12 15 18 9"/>,
                chevronUp: <polyline points="18 15 12 9 6 15"/>,
                chevronLeft: <polyline points="15 18 9 12 15 6"/>,
                chevronRight: <polyline points="9 18 15 12 9 6"/>,
                close: <><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></>,
                list: <><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></>,
                kakao: <path d="M12 3C7.03 3 3 6.06 3 9.83c0 2.43 1.66 4.56 4.14 5.76-.17.63-.61 2.29-.7 2.63-.12.43.14.43.3.33.12-.08 1.95-1.32 2.73-1.85.83.1 1.68.16 2.53.16 4.97 0 9-3.06 9-6.83C21 6.06 16.97 3 12 3Z" fill="currentColor" stroke="none"/>,
                alert: <><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></>,
                lock: <><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></>,
                unlock: <><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></>
            };
            return (
                <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
                    {icons[name]}
                </svg>
            );
        };

        function App() {
            // Firebase 연동 상태
            const [user, setUser] = useState(null);
            const [isDbReady, setIsDbReady] = useState(false);
            const [isSyncing, setIsSyncing] = useState(false);
            const [dbError, setDbError] = useState(''); 

            // 권한(비밀번호) 상태
            const [isAuthenticated, setIsAuthenticated] = useState(() => localStorage.getItem(`golf_auth_${appId}`) === 'true');

            // 로컬 UI 상태
            const [showToast, setShowToast] = useState(false);
            const [toastMessage, setToastMessage] = useState('');
            const [isSettingOpen, setIsSettingOpen] = useState(false);
            const [isResetConfirmOpen, setIsResetConfirmOpen] = useState(false);
            const [isScoreboardOpen, setIsScoreboardOpen] = useState(false);
            const [editingIdx, setEditingIdx] = useState(-1);
            const editInputRef = useRef(null);

            // 권한 인증 모달 상태 추가
            const [isAuthModalOpen, setIsAuthModalOpen] = useState(false);
            const [authPassword, setAuthPassword] = useState('');
            const pendingActionRef = useRef(null);

            // 롱프레스(길게 누르기) 구현을 위한 ref 추가
            const pressTimerRef = useRef(null);
            const isLongPressRef = useRef(false);

            // 클라우드 동기화 타겟 상태들 (5인 설정으로 전환)
            const defaultPlayers = ['닉네임방랑자', '달화백', '싱글댕이', '공나방의뒷땅', '쌉드래곤'];
            // 5인 요금제 (오전 인당 2만/총10만, 오후 인당 2.7만/총13.5만)
            const defaultFeeSettings = { 
                morning: [0, 10000, 20000, 30000, 40000], 
                afternoon: [0, 15000, 30000, 40000, 50000] 
            };
            const [players, setPlayers] = useState(defaultPlayers);
            const [isStarted, setIsStarted] = useState(false);
            const [feeMode, setFeeMode] = useState('morning');
            const [feeSettings, setFeeSettings] = useState(defaultFeeSettings);
            
            // holes 구조 확장 (1인 soloIndex, soloPoints 추가)
            const [holes, setHoles] = useState(Array.from({ length: 18 }, (_, i) => ({ 
                number: i + 1, 
                soloIndex: null, // 1인 플레이어
                soloPoints: 0,   // 1인 플레이어의 점수
                winners: [],     // 나머지 중 2:2 승자 2명
                points: 1,       // 2:2 점수
                isDraw: false 
            })));
            const [currentHoleIdx, setCurrentHoleIdx] = useState(0);

            // Firebase 초기화 및 인증
            useEffect(() => {
                if (!firebaseConfig) return;
                let isMounted = true;
                
                const initFirebase = async () => {
                    if (!window.FirebaseSDK && !window.FirebaseSDKError) {
                        await Promise.race([
                            new Promise(r => window.addEventListener('firebaseLoaded', r)),
                            new Promise(r => setTimeout(r, 8000))
                        ]);
                    }
                    if (!isMounted) return;
                    if (window.FirebaseSDKError || !window.FirebaseSDK) {
                        setDbError("통신 지연 (새로고침 해주세요)");
                        return;
                    }
                    
                    const { initializeApp, getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged, getFirestore } = window.FirebaseSDK;
                    
                    try {
                        if (!auth) {
                            const app = initializeApp(firebaseConfig);
                            auth = getAuth(app);
                            db = getFirestore(app);
                        }

                        if (initialAuthToken) await signInWithCustomToken(auth, initialAuthToken);
                        else await signInAnonymously(auth);

                        onAuthStateChanged(auth, (u) => {
                            if (isMounted) {
                                setUser(u);
                                setIsDbReady(!!u);
                            }
                        });
                    } catch (e) { 
                        console.error("Auth Error", e);
                        setDbError(e.code || "도메인 승인 필요");
                    }
                };
                
                initFirebase();
                return () => { isMounted = false; };
            }, []);

            // 실시간 데이터 리스너 (Firestore -> Local)
            useEffect(() => {
                if (!isDbReady || !user) return;
                const { doc, onSnapshot } = window.FirebaseSDK;
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'gameState', 'current');
                
                const unsubscribe = onSnapshot(docRef, (docSnap) => {
                    if (docSnap.exists()) {
                        const data = docSnap.data();
                        if (data.players) setPlayers(data.players);
                        if (data.isStarted !== undefined) setIsStarted(data.isStarted);
                        if (data.feeMode) setFeeMode(data.feeMode);
                        if (data.feeSettings) setFeeSettings(data.feeSettings);
                        if (data.holes) setHoles(data.holes);
                        if (data.currentHoleIdx !== undefined) setCurrentHoleIdx(data.currentHoleIdx);
                    }
                }, (error) => console.error("Sync Error:", error));
                
                return () => unsubscribe();
            }, [isDbReady, user]);

            // 상태 업데이트 및 동기화 함수
            const updateGameState = async (updates) => {
                if (updates.players !== undefined) setPlayers(updates.players);
                if (updates.isStarted !== undefined) setIsStarted(updates.isStarted);
                if (updates.feeMode !== undefined) setFeeMode(updates.feeMode);
                if (updates.feeSettings !== undefined) setFeeSettings(updates.feeSettings);
                if (updates.holes !== undefined) setHoles(updates.holes);
                if (updates.currentHoleIdx !== undefined) setCurrentHoleIdx(updates.currentHoleIdx);

                if (!isAuthenticated) return; 

                if (!isDbReady || !user) return;
                setIsSyncing(true);
                try {
                    const { doc, setDoc } = window.FirebaseSDK;
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'gameState', 'current');
                    await setDoc(docRef, updates, { merge: true });
                } catch (e) { console.error("Save Error", e); }
                finally { setTimeout(() => setIsSyncing(false), 500); }
            };

            const handleAuthAction = (actionFn, isStartAction = false) => {
                if (isAuthenticated) {
                    if (actionFn) actionFn();
                    return;
                }
                pendingActionRef.current = { fn: actionFn, isStartAction };
                setAuthPassword('');
                setIsAuthModalOpen(true);
            };

            const handleAuthSubmit = (e) => {
                if (e) e.preventDefault();
                if (authPassword === '7905') {
                    setIsAuthenticated(true);
                    localStorage.setItem(`golf_auth_${appId}`, 'true');
                    setToastMessage('인증 성공! 권한이 부여되었습니다.');
                    setShowToast(true);
                    setIsAuthModalOpen(false);
                    if (pendingActionRef.current?.fn) pendingActionRef.current.fn();
                    pendingActionRef.current = null;
                } else {
                    setToastMessage('비밀번호가 일치하지 않습니다.');
                    setShowToast(true);
                    setAuthPassword('');
                }
            };

            const changeHole = (newIdx) => {
                setCurrentHoleIdx(newIdx); 
                if (isAuthenticated) updateGameState({ currentHoleIdx: newIdx });
            };

            useEffect(() => {
                if (showToast) {
                    const timer = setTimeout(() => setShowToast(false), 2000);
                    return () => clearTimeout(timer);
                }
            }, [showToast]);

            useEffect(() => {
                if (editingIdx !== -1 && editInputRef.current) {
                    editInputRef.current.focus();
                    editInputRef.current.select();
                }
            }, [editingIdx]);

            // 계산 로직 (5인: 1인 점수 + 2:2 점수 합산)
            const totals = useMemo(() => {
                const scores = [0, 0, 0, 0, 0];
                holes.forEach(hole => {
                    // 1인(Solo) 점수 누적
                    if (hole.soloIndex !== null && hole.soloIndex !== undefined && !hole.isDraw) {
                        scores[hole.soloIndex] += (hole.soloPoints || 0);
                    }
                    // 나머지 4명(2:2) 점수 누적
                    if (hole.winners.length === 2 && !hole.isDraw) {
                        for (let i = 0; i < 5; i++) {
                            if (i === hole.soloIndex) continue; // 1인은 2:2 점수 제외
                            if (hole.winners.includes(i)) {
                                scores[i] += hole.points;
                            } else {
                                scores[i] -= hole.points;
                            }
                        }
                    }
                });
                return scores;
            }, [holes]);

            const rankingInfo = useMemo(() => {
                if (feeMode === 'none') return null;
                const playerData = players.slice(0, 5).map((name, index) => ({ index, name, score: totals[index] })).sort((a, b) => b.score - a.score);
                const fees = new Array(5).fill(0);
                const config = feeSettings[feeMode];
                if (!config) return null;

                const groups = [];
                playerData.forEach(p => {
                    if (groups.length > 0 && groups[groups.length - 1][0].score === p.score) groups[groups.length - 1].push(p);
                    else groups.push([p]);
                });
                let currentRank = 0;
                groups.forEach(group => {
                    const count = group.length;
                    let sumFee = 0;
                    for (let i = 0; i < count; i++) sumFee += config[currentRank + i] || 0;
                    const avgFee = Math.round(sumFee / count);
                    group.forEach(p => fees[p.index] = avgFee);
                    currentRank += count;
                });
                return fees;
            }, [totals, feeMode, players, feeSettings]);

            const executeReset = () => {
                const resetHoles = Array.from({ length: 18 }, (_, i) => ({ number: i + 1, soloIndex: null, soloPoints: 0, winners: [], points: 1, isDraw: false }));
                updateGameState({ holes: resetHoles, isStarted: false, feeMode: 'morning', currentHoleIdx: 0, players: defaultPlayers, feeSettings: defaultFeeSettings });
                setIsResetConfirmOpen(false);
                setToastMessage('모든 화면이 초기화되었습니다.');
                setShowToast(true);
            };

            // 5인 (2:2:1) 토글 로직 (짧게 누르면 +1, 길게 누르면 -1)
            const executePlayerToggle = (holeIndex, playerIndex, isLongPress) => {
                const newHoles = [...holes];
                
                // 이전 홀 건너뛰었을 때 자동 비김 처리
                for (let i = 0; i < holeIndex; i++) {
                    if ((newHoles[i].soloIndex === null || newHoles[i].soloIndex === undefined) && !newHoles[i].isDraw) {
                        newHoles[i] = { ...newHoles[i], isDraw: true };
                    }
                }
                
                const hole = { ...newHoles[holeIndex] };
                hole.isDraw = false;
                
                const isSoloSelected = hole.soloIndex !== null && hole.soloIndex !== undefined;
                const isSolo = hole.soloIndex === playerIndex;
                const isWinner = hole.winners.includes(playerIndex);
                const isHoleDone = hole.winners.length === 2; // 1명 빼고 나머지 4명 중 2명 승자

                if (!isSoloSelected) {
                    // Step 1: 처음 누른 사람을 1인(Solo)으로 지정 (짧게: +1, 길게: -1)
                    hole.soloIndex = playerIndex;
                    hole.soloPoints = isLongPress ? -1 : 1;
                } else if (isSolo) {
                    // 1인을 또 누르면 기입된 점수에서 더하거나 뺌 (순환 없음)
                    if (isLongPress) {
                        hole.soloPoints -= 1; // 길게 누르면 현재 점수에서 1점 차감
                    } else {
                        hole.soloPoints += 1; // 짧게 누르면 현재 점수에서 1점 추가
                    }
                } else if (isWinner) {
                    // 이미 이긴 사람을 또 누르면 점수 증가
                    if (hole.points < 10) {
                        hole.points += 1;
                    } else {
                        hole.winners = hole.winners.filter(id => id !== playerIndex);
                        if (hole.winners.length === 0) hole.points = 1;
                    }
                } else if (!isHoleDone) {
                    // 아직 이긴 사람이 다 안 찼으면 승자로 추가
                    hole.winners = [...hole.winners, playerIndex];
                } else {
                    // 승자 2명이 꽉 찼는데 진 사람을 누른 경우 (점수 하락)
                    if (hole.points > 1) {
                        hole.points -= 1;
                    } else {
                        hole.winners = [];
                        hole.points = 1;
                    }
                }
                newHoles[holeIndex] = hole;
                updateGameState({ holes: newHoles });
            };

            // 터치(마우스) 프레스 이벤트 핸들러들
            const handlePressStart = (holeIndex, playerIndex) => {
                isLongPressRef.current = false;
                pressTimerRef.current = setTimeout(() => {
                    isLongPressRef.current = true;
                    handleAuthAction(() => executePlayerToggle(holeIndex, playerIndex, true));
                }, 500); // 0.5초 누르면 롱프레스로 인식
            };

            const handlePressEnd = (holeIndex, playerIndex) => {
                if (pressTimerRef.current) {
                    clearTimeout(pressTimerRef.current);
                    pressTimerRef.current = null;
                }
                if (!isLongPressRef.current) {
                    // 짧게 눌렀을 때
                    handleAuthAction(() => executePlayerToggle(holeIndex, playerIndex, false));
                }
            };

            const handlePressCancel = () => {
                if (pressTimerRef.current) {
                    clearTimeout(pressTimerRef.current);
                    pressTimerRef.current = null;
                }
            };

            const handleDrawToggle = () => {
                handleAuthAction(() => {
                    const n = [...holes]; 
                    const h = n[currentHoleIdx];
                    h.isDraw = !h.isDraw; 
                    h.soloIndex = null;
                    h.soloPoints = 0;
                    h.winners = []; 
                    h.points = 1; 
                    updateGameState({ holes: n });
                });
            };

            const handleShare = async () => {
                const currentUrl = window.location.href;
                let lastHole = 0;
                holes.forEach(h => { if(h.isDraw || h.winners.length === 2) lastHole = h.number; });
                
                const summary = players.slice(0, 5).map((p, i) => {
                    const score = totals[i];
                    return `${p}: ${score > 0 ? '+' : ''}${score}점${rankingInfo ? ` (${rankingInfo[i].toLocaleString()}원)` : ''}`;
                }).join('\n');

                const feeLabel = feeMode === 'none' ? '' : ` [${feeMode === 'morning' ? '오전' : '오후'} 내기]`;
                const text = `⛳️ [좌탄우탄 5인(2:2:1) 스코어] ${lastHole}홀 진행${feeLabel}\n\n${summary}\n\n👇 아래 링크로 들어오시면 실시간 점수판을 같이 볼 수 있습니다.\n${currentUrl}`;

                if (navigator.share) {
                    try { await navigator.share({ title: '좌탄우탄 스코어', text: text }); } 
                    catch (err) { copyToClipboard(text); }
                } else { copyToClipboard(text); }
            };

            const copyToClipboard = (text) => {
                const textArea = document.createElement("textarea");
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.select();
                try {
                    document.execCommand('copy');
                    setToastMessage('복사되었습니다! 카톡에 붙여넣으세요.');
                    setShowToast(true);
