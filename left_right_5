                    {/* 전체 스코어보드 모달 */}
                    {isScoreboardOpen && (
                        <div className="fixed inset-0 z-[100] bg-[#f8fafc] flex flex-col animate-slide-up">
                            <div className="bg-emerald-600 text-white px-5 py-4 flex justify-between items-center shadow-md shrink-0">
                                <h2 className="font-bold text-lg">전체 스코어보드</h2>
                                <button onClick={() => setIsScoreboardOpen(false)} className="w-8 h-8 flex items-center justify-center bg-white/20 rounded-full active:scale-90 transition-transform">
                                    <Icon name="close" size={18} />
